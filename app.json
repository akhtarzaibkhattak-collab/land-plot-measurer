{
  "expo": {
    "name": "Land Plot Measurer",
    "slug": "land-plot-measurer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "land-plot-measurer",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1120"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.akhtarzaibkhattak.landplotmeasurer"
    },
    "android": {
      "package": "com.akhtarzaibkhattak.landplotmeasurer",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0B1120"
      },
      "permissions": []
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "4fae1843-d2d0-4f21-808d-b39daff33cc1"
      }
    },
    "owner": "akhtarzaib"
  }
}
